{
  "id": "gridfinity_cup",
  "title": "Gridfinity Extended — Cup",
  "author": "ostat",
  "author_url": "https://github.com/ostat/gridfinity_extended_openscad",
  "license": "MIT",
  "scad_file": "generators/gridfinity_extended/gridfinity_basic_cup.scad",
  "sections": [
    {
      "label": "Size",
      "params": ["width", "depth", "height"]
    },
    {
      "label": "Features",
      "params": ["lip_style", "wall_thickness", "floor_thickness", "enable_magnets"]
    }
  ],
  "params": [
    {
      "id": "width",
      "label": "Width",
      "scad_var": "width",
      "type": "gridfinity_dim",
      "default": [2, 0],
      "min": 1,
      "tooltip": "Width in grid units (42mm each), or override in mm"
    },
    {
      "id": "depth",
      "label": "Depth",
      "scad_var": "depth",
      "type": "gridfinity_dim",
      "default": [1, 0],
      "min": 1,
      "tooltip": "Depth in grid units (42mm each), or override in mm"
    },
    {
      "id": "height",
      "label": "Height",
      "scad_var": "height",
      "type": "gridfinity_dim",
      "default": [3, 0],
      "min": 1,
      "tooltip": "Height in 7mm grid units, or override in mm"
    },
    {
      "id": "lip_style",
      "label": "Lip Style",
      "scad_var": "lip_style",
      "type": "enum",
      "options": ["normal", "reduced", "reduced_double", "minimum", "none"],
      "default": "normal"
    },
    {
      "id": "wall_thickness",
      "label": "Wall Thickness",
      "scad_var": "wall_thickness",
      "type": "float",
      "default": 0.95,
      "min": 0.1,
      "max": 5.0,
      "step": 0.05,
      "tooltip": "Outer wall thickness in mm (0 = auto)"
    },
    {
      "id": "floor_thickness",
      "label": "Floor Thickness",
      "scad_var": "floor_thickness",
      "type": "float",
      "default": 0.7,
      "min": 0.0,
      "max": 5.0,
      "step": 0.05
    },
    {
      "id": "enable_magnets",
      "label": "Magnet Holes",
      "scad_var": "enable_magnets",
      "type": "bool",
      "default": false
    }
  ]
}
